---
// Social/contact links reused across pages
interface Props {
  hideRss?: boolean;
}
const { hideRss = false } = Astro.props;
---
<ul class="social-links-list">
  <li>
    <a href="https://t.me/+tCVz3Z4dTkhjMzZk" rel="noopener noreferrer" target="_blank" class="social-link">
      <svg class="icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="color:#229ED9">
        <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
      </svg>
      Telegram
    </a>
  </li>
  {!hideRss && (
    <li>
      <a href="/rss.xml" class="social-link">
        <svg class="icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="color:#f26522">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
        </svg>
        RSS
      </a>
    </li>
  )}
</ul>

<style>
  .social-links-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .icon {
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
  }
  .social-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--gray-light);
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    font-size: 0.9rem;
    color: var(--text);
    font-weight: 500;
    transition: background 0.15s, color 0.15s;
  }
  .social-link:hover {
    background: var(--orange-light);
    color: var(--orange-dark);
    text-decoration: none;
  }
</style>
