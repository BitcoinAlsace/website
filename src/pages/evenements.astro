---
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import PageBanner from '../components/PageBanner.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events', ({ data }) => !data.draft);
const sortedEvents = allEvents.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const upcomingEvents = sortedEvents.filter(e => e.data.date >= new Date());
const pastEvents = sortedEvents.filter(e => e.data.date < new Date());
---
<Layout
  title="Évènements"
  description="Retrouvez tous les événements Bitcoin Alsace : meetups mensuels, conférences, ateliers et actualités."
>
  <PageHero title="Évènements" description="Meetups, conférences, ateliers — rejoignez la communauté Bitcoin en Alsace." />

  <PageBanner src="/images/pages/final1_crop.webp" alt="Évènements Bitcoin Alsace" />

  <div class="page-content">
    <div class="container">

      <section class="meetup-intro">
        <h2>🤝 Mensuel : Rencontre Bitcoin, dite « Bitcoin Meetup »</h2>
        <p>
          Les Bitcoin Meetup sont des rassemblements communautaires informels où les passionnés de Bitcoin se réunissent pour discuter, apprendre et échanger. Il s'agit de rencontres locales, souvent organisées dans des cafés, bars ou espaces publics, sans structure hiérarchique formelle.
        </p>
        <p>
          ℹ️ Les Bitcoin Meetup sont <strong>100% gratuits</strong> : rejoignez-nous le <strong>deuxième mercredi de chaque mois</strong>.
        </p>
        <a href="https://t.me/+tCVz3Z4dTkhjMzZk" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
          Plus d'info sur Telegram
        </a>
      </section>

      {upcomingEvents.length > 0 && (
        <section class="events-block">
          <h2 class="section-title">🔮 Évènements <span>à venir</span></h2>
          <div class="events-grid">
            {upcomingEvents.map(event => (
              <EventCard
                title={event.data.title}
                date={event.data.date}
                endDate={event.data.endDate}
                category={event.data.category}
                image={event.data.image}
                slug={event.id}
              />
            ))}
          </div>
        </section>
      )}

      {upcomingEvents.length === 0 && (
        <div class="no-events">
          <p>Aucun événement à venir pour le moment. Consultez nos réseaux pour rester informé !</p>
        </div>
      )}

      {pastEvents.length > 0 && (
        <section class="events-block">
          <h2 class="section-title">Événements <span>passés</span></h2>
          <div class="events-grid">
            {pastEvents.map(event => (
              <EventCard
                title={event.data.title}
                date={event.data.date}
                endDate={event.data.endDate}
                category={event.data.category}
                image={event.data.image}
                slug={event.id}
              />
            ))}
          </div>
        </section>
      )}

      <div class="contribute-box card">
        <h3>Ajouter un événement</h3>
        <p>
          Les événements de ce site sont écrits en Markdown et hébergés sur Git.
          Toute personne peut contribuer en ouvrant une pull request.
        </p>
        <a
          href="https://github.com/bitcoinalsace/website/new/main/src/content/events"
          class="btn btn-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          Proposer un événement sur GitHub →
        </a>
      </div>

    </div>
  </div>
</Layout>

<style>


  .meetup-intro {
    background: var(--gray-light);
    padding: 2rem;
    border-radius: var(--radius);
    margin-bottom: 3rem;
  }
  .meetup-intro h2 {
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }
  .meetup-intro p {
    margin-bottom: 1rem;
    color: var(--text);
  }
  .meetup-intro .btn {
    margin-top: 0.5rem;
    display: inline-block;
  }

  .events-block { margin-bottom: 3rem; }
  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .no-events {
    background: var(--gray-light);
    padding: 2rem;
    border-radius: var(--radius);
    text-align: center;
    color: var(--gray);
    margin-bottom: 3rem;
  }

  .contribute-box {
    background: var(--orange-light);
    border-color: #f7c48a;
    margin-top: 1rem;
  }
  .contribute-box h3 { margin-bottom: 0.5rem; }
  .contribute-box p { margin-bottom: 1rem; color: var(--text); }
</style>
