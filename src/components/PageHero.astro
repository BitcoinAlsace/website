---
interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
}

const { title, description, image, imageAlt = '' } = Astro.props;
---

<div class={`page-hero${image ? ' page-hero--banner' : ''}`}>
  {image && <img class="page-hero-img" src={image} alt={imageAlt} />}
  {image && <div class="page-hero-overlay" aria-hidden="true" />}
  <div class="container page-hero-content">
    <slot name="before-title" />
    <h1>{title}</h1>
    {description && <p>{description}</p>}
    <slot />
  </div>
</div>

<style>
  /* ── Base (no image) ── */
  .page-hero {
    position: relative;
    background: linear-gradient(135deg, var(--orange-light), var(--white));
    border-bottom: 1px solid var(--border);
    padding: 3rem 0;
    overflow: hidden;
    --page-hero-muted-color: var(--gray);
  }
  .page-hero h1 { margin-bottom: 0.5rem; }
  .page-hero p {
    color: var(--gray);
    font-size: 1.05rem;
  }

  /* ── Banner mode (image provided) ── */
  .page-hero--banner {
    background: none;
    border-bottom: none;
    height: clamp(240px, 45.6vh, 528px);
    display: flex;
    align-items: flex-end;
    padding: 0;
    --page-hero-muted-color: rgba(255, 255, 255, 0.82);
  }

  .page-hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.78) 0%,
      rgba(0, 0, 0, 0.45) 45%,
      rgba(0, 0, 0, 0.12) 100%
    );
  }

  .page-hero-content {
    position: relative;
    z-index: 1;
  }

  .page-hero--banner .page-hero-content {
    width: 100%;
    padding-bottom: 2rem;
  }

  .page-hero--banner h1 {
    color: #fff;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.55);
  }

  .page-hero--banner p {
    color: var(--page-hero-muted-color);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5);
    font-size: 1.05rem;
  }
</style>
