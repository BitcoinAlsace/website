---
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import PageHero from '../components/PageHero.astro';
---
<Layout
  title="Donation"
  description="Soutenez Bitcoin Alsace par un don en Bitcoin via Lightning Network. Adresse Lightning : bitcoinalsace@blink.sv"
>
  <PageHero title="Donation 🧡" description="Soutenez notre mission d'éducation autour de Bitcoin en Alsace." />

  <div class="page-content">
    <div class="container donation-layout">

      <div class="donation-main">

        <div class="card lightning-card">
          <img src="/images/pages/Bitcoin-Alsace-Donation-LN-Blink-2.webp" alt="Donation Bitcoin Alsace via Lightning" class="donation-img" />
          <h2>Lightning Network ⚡ = Seconde couche ₿ (L2)</h2>
          <p class="lightning-lead">
            Idéal même pour des micro-dons.
          </p>

          <div class="lightning-address-box">
            <span class="lightning-label">Adresse Lightning</span>
            <code class="lightning-address" id="lightning-address">bitcoinalsace@blink.sv</code>
            <button class="copy-btn" id="copy-btn" aria-label="Copier l'adresse Lightning">
              Copier
            </button>
          </div>

          <p class="lightning-merci">MERCI 🧡</p>
        </div>

        <div class="card">
          <h3>Vous préférez adhérer ?</h3>
          <p>
            En adhérant à l'association pour 25€/an, vous participez activement à notre gouvernance
            et votez lors des assemblées générales.
          </p>
          <a href="/adherer" class="btn btn-primary" style="margin-top:0.75rem;">
            Adhérer à Bitcoin Alsace →
          </a>
        </div>

      </div>

      <aside class="sidebar">
        <div class="card sidebar-card">
          <h3>Nous suivre</h3>
          <SocialLinks />
        </div>

        <div class="card sidebar-card">
          <h3>Ressources gratuites</h3>
          <ul class="download-list">
            <li>
              <a href="/bitcoin.pdf" target="_blank">
                📄 Bitcoin Whitepaper (FR)
              </a>
            </li>
            <li>
              <a href="/cypherpunks-manifesto-fr.pdf" target="_blank">
                📄 Manifeste Cypherpunks (FR)
              </a>
            </li>
          </ul>
        </div>
      </aside>

    </div>
  </div>
</Layout>

<style>

  .donation-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 3rem;
    align-items: start;
    padding: 3rem 1.5rem;
  }
  @media (max-width: 900px) {
    .donation-layout { grid-template-columns: 1fr; padding: 2rem 1.5rem; }
  }

  .donation-main { display: flex; flex-direction: column; gap: 1.5rem; }

  /* Lightning card */
  .lightning-card {
    text-align: center;
    background: linear-gradient(135deg, var(--orange-light), var(--white));
    border-color: var(--border);
    padding: 2.5rem 2rem;
  }
  .donation-img {
    width: 100%;
    max-width: 320px;
    height: auto;
    display: block;
    margin: 0 auto 1.5rem;
    border-radius: var(--radius);
  }
  .lightning-card h2 { margin-bottom: 0.5rem; }
  .lightning-lead { color: var(--gray); margin-bottom: 1.5rem; }
  .lightning-merci { font-size: 1.5rem; font-weight: 700; margin-top: 1rem; }

  .lightning-address-box {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--gray-light);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    margin: 0 auto 1.25rem;
    max-width: 420px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .lightning-label {
    font-size: 0.8rem;
    color: var(--gray);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: 100%;
    text-align: left;
  }
  .lightning-address {
    font-size: 1rem;
    font-weight: 700;
    color: var(--black);
    flex: 1;
    word-break: break-all;
  }
  .copy-btn {
    background: var(--orange);
    color: white;
    border: none;
    border-radius: var(--radius);
    padding: 0.35rem 0.8rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .copy-btn:hover { background: var(--orange-dark); }
  .copy-btn.copied { background: #059669; }

  .lightning-tip { font-size: 0.875rem; color: var(--gray); max-width: 420px; margin: 0 auto; }

  /* Info card */
  .info-card h3 { margin-bottom: 0.75rem; }
  .info-card ul { margin-bottom: 1rem; }
  .info-card li { margin-bottom: 0.3rem; }

  /* Sidebar */
  .sidebar-card { margin-bottom: 1.5rem; }
  .sidebar-card h3 {
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--orange);
    display: inline-block;
  }
  .download-list { list-style: none; padding: 0; }
  .download-list li { margin-bottom: 0.5rem; }
  .download-list a { font-size: 0.9rem; }
</style>

<script>
  const btn = document.getElementById('copy-btn');
  const address = document.getElementById('lightning-address');
  btn?.addEventListener('click', async () => {
    if (!address) return;
    await navigator.clipboard.writeText(address.textContent?.trim() ?? '');
    btn.textContent = 'Copié !';
    btn.classList.add('copied');
    setTimeout(() => {
      btn.textContent = 'Copier';
      btn.classList.remove('copied');
    }, 2000);
  });
</script>
